# Example server environment variables for LogiTrack
# Copy this file to .env and fill in your own values.

PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173,https://your-frontend-domain.netlify.app
FRONTEND_URL=https://your-frontend-domain.netlify.app

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/logitrack?retryWrites=true&w=majority

# JWT secrets
JWT_ACCESS_SECRET=change_this_to_a_secure_random_string
JWT_REFRESH_SECRET=change_this_to_a_secure_random_string

# Optional AI key
GEMINI_API_KEY=your_gemini_api_key_here
